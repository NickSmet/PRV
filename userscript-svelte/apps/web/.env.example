# Reportus API (used by apps/web server routes)
#
# `REPORTUS_BASIC_AUTH` may be either:
# - the full header value: `Basic <base64(user:pass)>`, or
# - just the base64 portion: `<base64(user:pass)>`
# The shared client (`packages/report-api`) will normalize both.
REPORTUS_BASE_URL=https://reportus.prls.net
REPORTUS_BASIC_AUTH=Basic REPLACE_ME

# ── AI Chat ──────────────────────────────────────────────────
# The chat feature uses OpenAI (or Azure OpenAI) to power an
# AI assistant that can analyze reports via MCP tool calls.
#
# Provider: 'auto' | 'openai' | 'azure'
#   auto — uses Azure if AZURE_OPENAI_API_KEY is set, else OpenAI
AI_CHAT_PROVIDER=auto

# API mode: 'responses' (default) or 'chat_completions'
AI_CHAT_API_MODE=responses

# Model name (or Azure deployment name)
AI_CHAT_MODEL=gpt-4o-mini

# ── OpenAI credentials ──────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME
# OPENAI_BASE_URL=              # optional; override for proxies

# ── Azure OpenAI credentials (alternative to plain OpenAI) ──
# Uncomment and fill these to use Azure instead of OpenAI.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
